# Supabase 프로젝트 설정 (https://supabase.com/dashboard 에서 프로젝트 생성 후 Project Settings > API 에서 확인)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 생성형 AI 키는 더 이상 서버 환경변수가 아니라 교사별로 앱 안에서 등록한다.
# 각 교사가 로그인 후 "계정 설정 > 생성형 AI API 키"에서 제공사(Google Gemini / OpenAI / Anthropic)와
# 본인 키를 입력하면, 그 교사의 AI 채점·피드백·문항추출·분석이 해당 키로 실행된다(teacher_ai_credentials
# 테이블에 서버 전용으로 저장). 따라서 여기에 공용 GEMINI_API_KEY를 둘 필요가 없다.

# Supabase CLI 연동용 (선택 — `npx supabase db push`로 마이그레이션을 직접 적용하고 싶을 때만 필요)
SUPABASE_ACCESS_TOKEN=
SUPABASE_DB_PASSWORD=
