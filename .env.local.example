# Supabase 프로젝트 설정 (https://supabase.com/dashboard 에서 프로젝트 생성 후 Project Settings > API 에서 확인)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Gemini API 키 (https://aistudio.google.com/apikey 에서 발급)
GEMINI_API_KEY=
# 선택: 기본값은 gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash

# Supabase CLI 연동용 (선택 — `npx supabase db push`로 마이그레이션을 직접 적용하고 싶을 때만 필요)
SUPABASE_ACCESS_TOKEN=
SUPABASE_DB_PASSWORD=
